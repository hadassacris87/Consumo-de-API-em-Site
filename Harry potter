<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Grifinória</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0b0b0b;
      color: white;
    }

    header {
      padding: 20px;
      font-size: 26px;
      font-weight: bold;
      color: #D3A625; 
      background: #740001; 
    }

    
    .banner {
      height: 400px;
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: flex-end;
      padding: 30px;
      background-blend-mode: multiply;
      background-color: rgba(116, 0, 1, 0.6);
    }

    .banner h1 {
      font-size: 30px;
      color: #D3A625;
      margin: 0;
    }

   
    section {
      padding: 20px;
    }

    h2 {
      color: #D3A625;
    }

    
    .row {
      display: flex;
      overflow-x: auto;
      gap: 12px;
    }

    .card {
      min-width: 150px;
      transition: transform 0.3s;
    }

    .card:hover {
      transform: scale(1.1);
    }

    .card img {
      width: 100%;
      border-radius: 10px;
      border: 2px solid #D3A625;
    }

    .card p {
      text-align: center;
      font-size: 14px;
      color: #D3A625;
    }

    .row::-webkit-scrollbar {
      display: none;
    }
  </style>
</head>
<body>

<header>GRIFINÓRIA</header>

<div class="banner" id="banner">
  <h1 id="bannerTitle"></h1>
</div>

<section>
  <h2>🦁 Membros da Grifinória:</h2>
  <div class="row" id="gryffindorRow"></div>
</section>

<script>
  fetch("https://hp-api.onrender.com/api/characters")
    .then(res => res.json())
    .then(data => {

      const gryffindor = data.filter(c => c.house === "Gryffindor" && c.image);


      const destaque = gryffindor[0];
      document.getElementById("banner").style.backgroundImage = `url(${destaque.image})`;
      document.getElementById("bannerTitle").innerText = destaque.name;

     
      const row = document.getElementById("gryffindorRow");

      gryffindor.forEach(char => {
        const div = document.createElement("div");
        div.className = "card";

        div.innerHTML = `
          <img src="${char.image}" alt="${char.name}">
          <p>${char.name}</p>
        `;

        row.appendChild(div);
      });

    });
</script>

</body>
</html>
